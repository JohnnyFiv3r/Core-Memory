{
  "version": "v1",
  "service": "core_memory.integrations.http.server",
  "auth": {
    "env": "CORE_MEMORY_HTTP_TOKEN",
    "modes": ["Authorization: Bearer <token>", "X-Memory-Token: <token>"],
    "required_when_env_set": true
  },
  "endpoints": [
    {
      "method": "GET",
      "path": "/healthz",
      "authRequired": false,
      "response": {"ok": "bool"},
      "errors": []
    },
    {
      "method": "POST",
      "path": "/v1/memory/turn-finalized",
      "authRequired": "conditional",
      "requestSchema": "TurnFinalizedRequest",
      "requiredFields": ["session_id", "turn_id", "turns"],
      "response": {"accepted": "bool", "event_id": "string"},
      "errors": ["400 invalid_payload|invalid_content_length", "401 unauthorized", "413 payload_too_large"]
    },
    {
      "method": "POST",
      "path": "/v1/memory/classify-intent",
      "authRequired": "conditional",
      "requestSchema": "MemoryClassifyIntentRequest",
      "requiredFields": ["query"],
      "response": {"intent_class": "string", "causal_intent": "bool", "query_type_bucket": "string", "normalized": "object"},
      "errors": ["401 unauthorized"]
    },
    {
      "method": "POST",
      "path": "/v1/memory/search",
      "authRequired": "conditional",
      "requestSchema": "MemorySearchRequest",
      "requiredFields": ["request"],
      "notes": ["`form_submission` accepted as deprecated compatibility alias; use `request` for new callers"],
      "response": {"ok": "bool", "results": "array", "chains": "array", "confidence": "string", "suggested_next": "string", "warnings": "array"},
      "errors": ["401 unauthorized", "503 semantic_backend_unavailable"]
    },
    {
      "method": "POST",
      "path": "/v1/memory/trace",
      "authRequired": "conditional",
      "requestSchema": "MemoryTraceRequest",
      "requiredFields": [],
      "response": {"ok": "bool", "anchors": "array", "chains": "array", "grounding": "object", "hydration": "object"},
      "errors": ["401 unauthorized", "503 semantic_backend_unavailable (query-based trace only)"]
    },
    {
      "method": "POST",
      "path": "/v1/memory/execute",
      "authRequired": "conditional",
      "requestSchema": "MemoryExecuteRequest",
      "requiredFields": ["request"],
      "notes": ["Single-call canonical retrieval orchestration path"],
      "response": {"ok": "bool", "request": "object", "snapped": "object", "results": "array", "chains": "array", "grounding": "object", "confidence": "string", "next_action": "string", "warnings": "array", "explain": "object?"},
      "errors": ["401 unauthorized", "memory_execute_disabled", "memory_execute_causal_disabled", "503 semantic_backend_unavailable"]
    },
    {
      "method": "POST",
      "path": "/v1/memory/session-flush",
      "authRequired": "conditional",
      "requestSchema": "SessionFlushRequest",
      "requiredFields": ["session_id"],
      "response": {"ok": "bool"},
      "errors": ["401 unauthorized"]
    },
    {
      "method": "POST",
      "path": "/v1/memory/session-start",
      "authRequired": "conditional",
      "requestSchema": "SessionStartRequest",
      "requiredFields": ["session_id"],
      "response": {"ok": "bool", "created": "bool", "bead_id": "string"},
      "errors": ["401 unauthorized"]
    },
    {
      "method": "GET",
      "path": "/v1/memory/continuity",
      "authRequired": "conditional",
      "requestSchema": "query params",
      "requiredFields": [],
      "notes": ["Pure-read continuity surface; does not create session_start implicitly"],
      "response": {"ok": "bool", "format": "string", "records": "array?", "text": "string?"},
      "errors": ["401 unauthorized"]
    },
    {
      "method": "GET",
      "path": "/v1/memory/inspect/state",
      "authRequired": "conditional",
      "requestSchema": "query params",
      "requiredFields": [],
      "notes": ["Canonical inspect read model for dashboards/inspectors"],
      "response": {"ok": "bool", "memory": "object", "claims": "object", "entities": "object", "runtime": "object", "stats": "object"},
      "errors": ["401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "GET",
      "path": "/v1/beads/titles",
      "authRequired": "conditional",
      "requestSchema": "query params",
      "requiredFields": [],
      "response": {"ok": "bool", "titles": "object"},
      "notes": ["Read-only batch bead-title projection (comma-separated ids); missing/untitled/removed ids are omitted so callers fall back to the raw id."],
      "errors": ["401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "GET",
      "path": "/v1/memory/inspect/beads/{bead_id}",
      "authRequired": "conditional",
      "requestSchema": "path + query params",
      "requiredFields": ["bead_id"],
      "response": {"ok": "bool", "bead": "object"},
      "errors": ["401 unauthorized", "404 bead_not_found", "400 invalid_tenant_id"]
    },
    {
      "method": "GET",
      "path": "/v1/memory/inspect/beads/{bead_id}/hydrate",
      "authRequired": "conditional",
      "requestSchema": "path + query params",
      "requiredFields": ["bead_id"],
      "response": {"ok": "bool", "hydrated": "array", "requested_turn_ids": "array"},
      "errors": ["401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "GET",
      "path": "/v1/memory/inspect/claim-slots/{subject}/{slot}",
      "authRequired": "conditional",
      "requestSchema": "path + query params",
      "requiredFields": ["subject", "slot"],
      "response": {"ok": "bool", "slot_key": "string", "row": "object", "as_of": "string?"},
      "errors": ["401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "GET",
      "path": "/v1/memory/inspect/turns",
      "authRequired": "conditional",
      "requestSchema": "query params",
      "requiredFields": [],
      "response": {"ok": "bool", "items": "array", "cursor": "string", "next_cursor": "string?", "total": "int"},
      "errors": ["401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "GET",
      "path": "/v1/memory/association-coverage/summary",
      "authRequired": "conditional",
      "requestSchema": "query params",
      "requiredFields": [],
      "response": {"ok": "bool", "contract": "memory.association_coverage_summary.v1", "graph_revision": "string", "eligible_bead_count": "int", "active_association_count": "int", "isolated_eligible_bead_ids": "array", "candidate_status_counts": "object", "source_ingest_envelope_summary": "object", "source_ingest_envelope_refs": "array", "latest_runs": "array"},
      "errors": ["401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "GET",
      "path": "/v1/memory/semantic-task-runs",
      "authRequired": "conditional",
      "requestSchema": "query params",
      "requiredFields": [],
      "response": {"ok": "bool", "contract": "memory.semantic_task_runs.v1", "count": "int", "total_matching": "int", "results": "array"},
      "errors": ["401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "GET",
      "path": "/v1/memory/semantic-task-runs/summary",
      "authRequired": "conditional",
      "requestSchema": "query params",
      "requiredFields": [],
      "response": {"ok": "bool", "contract": "memory.semantic_task_summary.v1", "total_runs": "int", "latest_run_at": "string?", "latest_run": "object?", "counts": "object", "attention": "object", "errors": "object", "latency_ms": "object", "token_usage": "object", "recent": "array"},
      "errors": ["401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "GET",
      "path": "/v1/memory/association-candidates",
      "authRequired": "conditional",
      "requestSchema": "query params",
      "requiredFields": [],
      "response": {"ok": "bool", "contract": "memory.association_candidates.v1", "count": "int", "observation_count": "int", "results": "array"},
      "errors": ["401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "POST",
      "path": "/v1/memory/association-candidates/{candidate_id}/decide",
      "authRequired": "conditional",
      "requestSchema": "AssociationCandidateDecisionRequest",
      "requiredFields": ["candidate_id", "action"],
      "response": {"ok": "bool", "contract": "memory.association_candidate_decision.v1", "candidate_id": "string", "status": "string", "association_state_by_bead": "object", "association_ids": "array"},
      "errors": ["400 association_candidate_not_found", "400 invalid_association_candidate_action", "401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "POST",
      "path": "/v1/memory/association-runs",
      "authRequired": "conditional",
      "requestSchema": "AssociationRunRequest { source_ingest_envelope?: object, source_ingest_envelope_refs?: array }",
      "requiredFields": ["bead_ids|session_id|sweep"],
      "response": {"ok": "bool", "contract": "memory.association_run.v1", "run_id": "string", "status": "string", "association_state_by_bead": "object", "candidate_count": "int?", "judge_model": "string?", "source_ingest_envelope_refs": "array", "source_ingest_batch_ids": "array", "sweep_complete": "bool?"},
      "notes": ["Deterministic/source-local coverage emits candidates only; active association edges require judge-approved decisions.", "States include deferred, pending_judge, linked, no_supported_links, quarantined, judge_failed, failed, skipped_ineligible."],
      "errors": ["400 association_run_requires_bead_ids_or_session_id", "401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "GET",
      "path": "/v1/memory/association-runs/{run_id}",
      "authRequired": "conditional",
      "requestSchema": "path + query params",
      "requiredFields": ["run_id"],
      "response": {"ok": "bool", "run": "object"},
      "errors": ["401 unauthorized", "404 association_run_not_found", "400 invalid_tenant_id"]
    },
    {
      "method": "POST",
      "path": "/v1/memory/association-proposals",
      "authRequired": "conditional",
      "requestSchema": "AssociationProposalRequest",
      "requiredFields": ["associations"],
      "response": {"ok": "bool", "contract": "memory.association_proposals.v1", "accepted": "int", "appended": "int", "quarantined": "int", "association_ids": "array"},
      "errors": ["401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "POST",
      "path": "/v1/memory/beads/remove",
      "authRequired": "conditional",
      "requestSchema": "RemoveBeadsRequest",
      "requiredFields": ["bead_ids|bead_id", "reason"],
      "notes": ["Defaults to dry-run preview. Active removal requires apply=true, dry_run=false, and confirmed or authorized authority.", "Removes beads from active projection, prunes attached associations, appends bead_removed tombstones, retracts configured projections, and marks retrieval/trace indexes dirty.", "Supplying idempotency_key on apply enables original-result replay or idempotency_key_conflict for changed fingerprints."],
      "response": {"ok": "bool", "contract": "core_memory.remove_beads.v1", "applied": "bool", "removed_count": "int?", "removed_bead_ids": "array?", "projection_retry": "object?"},
      "errors": ["400 remove_beads_requires_bead_ids", "400 remove_beads_requires_reason", "400 remove_beads_requires_confirmed_or_authorized_actor", "400 idempotency_key_conflict", "401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "POST",
      "path": "/v1/memory/sources/remove",
      "authRequired": "conditional",
      "requestSchema": "RemoveSourceRequest",
      "requiredFields": ["source"],
      "notes": ["For source-object/file deletion cleanup. Source selector must include a strong identifier such as document_id, source_ref, ragie_document_id, raw_source_object_id, hydration_ref, or core_memory_unifying_id.", "Use source.selector for matching and source.metadata for audit-only metadata. Flat legacy source objects match only strong selector keys; extra fields are preserved as metadata.", "Event-hook authority may apply source cleanup without interactive user confirmation.", "limit bounds preview rows only; apply=true with dry_run=false removes every matching bead and reports matched_total/truncated/remaining_count."],
      "response": {"ok": "bool", "contract": "core_memory.remove_source.v1", "applied": "bool", "matched_count": "int", "matched_total": "int", "preview_count": "int", "truncated": "bool", "remaining_count": "int", "removed_count": "int?", "source_metadata": "object?"},
      "errors": ["400 source_selector_required", "400 source_selector_requires_strong_identifier", "400 remove_source_requires_event_hook_or_authorized_actor", "400 idempotency_key_conflict", "401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "POST",
      "path": "/v1/memory/maintain",
      "authRequired": "conditional",
      "requestSchema": "MaintainRequest",
      "requiredFields": ["action"],
      "notes": ["Unified governed facade for agent control-plane management. Supports remove_beads, tombstone_bead (single-bead semantic wrapper over remove_beads that retires one mistaken bead while preserving the bead_removed tombstone), remove_source, approval actions, queue ops, session lifecycle, association dispatch, Dreamer/entity proposal actions, SOUL revision actions, Myelination status/refresh, and correction actions.", "Destructive or mutating actions preview by default unless apply=true and dry_run=false. Dry-run previews run the same schema/authority preflight and return required_authority, authority_ok, and validation_errors.", "apply_association_proposals requires append_judged_association authority and judge provenance. Dreamer decisions route through candidate APIs; SOUL actions route through the structured revision store."],
      "response": {"ok": "bool", "contract": "core_memory.maintain.v1", "action": "string", "status": "string?", "applied": "bool?", "required_authority": "array?", "authority_ok": "bool?", "validation_errors": "array?"},
      "errors": ["400 unsupported_maintain_action", "400 maintain_action_required", "400 maintain_authority_required", "400 maintain_validation_failed", "401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "GET",
      "path": "/v1/ops/async-jobs/status",
      "authRequired": "conditional",
      "requestSchema": "query params",
      "requiredFields": [],
      "response": {"ok": "bool", "schema_version": "core_memory.async_jobs.v1", "queues": "object", "pending_total": "int", "processable_now": "int"},
      "errors": ["401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "POST",
      "path": "/v1/ops/async-jobs/enqueue",
      "authRequired": "conditional",
      "requestSchema": "AsyncJobsEnqueueRequest",
      "requiredFields": ["kind"],
      "notes": ["kind supports: semantic-rebuild, compaction, dreamer-run, neo4j-sync, health-recompute, association-pass, myelination-update, data-insight-poll, bead-retraction"],
      "response": {"ok": "bool", "schema_version": "core_memory.async_jobs.v1", "kind": "string", "queue": "object", "status": "object"},
      "errors": ["400 unknown_kind", "401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "POST",
      "path": "/v1/ops/async-jobs/run",
      "authRequired": "conditional",
      "requestSchema": "AsyncJobsRunRequest",
      "requiredFields": [],
      "notes": ["Always returns structured status payload; `ok=false` is reported in-body rather than non-200 status.", "run request supports max_side_effects for bounded side-effect drains."],
      "response": {"ok": "bool", "schema_version": "core_memory.async_jobs.v1", "semantic_run": "object", "compaction_run": "object", "side_effect_run": "object", "status_after": "object", "errors": "array"},
      "errors": ["401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "GET",
      "path": "/v1/ops/dreamer/candidates",
      "authRequired": "conditional",
      "requestSchema": "query params",
      "requiredFields": [],
      "response": {"ok": "bool", "count": "int", "results": "array"},
      "errors": ["401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "POST",
      "path": "/v1/ops/dreamer/candidates/decide",
      "authRequired": "conditional",
      "requestSchema": "DreamerCandidateDecideRequest",
      "requiredFields": ["candidate_id", "decision"],
      "response": {"ok": "bool", "candidate_id": "string", "status": "accepted|rejected", "applied": "object?"},
      "errors": ["400 invalid_decision", "400 candidate_not_found", "401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "GET",
      "path": "/v1/soul/files",
      "authRequired": "conditional",
      "requestSchema": "query params",
      "requiredFields": [],
      "response": {"ok": "bool", "subject": "string", "files": "array"},
      "notes": ["Read-only list of SOUL projection files and folded entry counts for the requested subject."],
      "errors": ["401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "GET",
      "path": "/v1/soul/files/{file_name}",
      "authRequired": "conditional",
      "requestSchema": "path + query params",
      "requiredFields": ["file_name"],
      "response": {"ok": "bool", "subject": "string", "file_name": "string", "markdown": "string", "entry_count": "int"},
      "notes": ["Read-only rendered markdown projection for one SOUL file."],
      "errors": ["400 invalid_target_file", "401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "GET",
      "path": "/v1/soul/files/{file_name}/entries",
      "authRequired": "conditional",
      "requestSchema": "path + query params",
      "requiredFields": ["file_name"],
      "response": {"ok": "bool", "contract": "soul.entries.v1", "subject": "string", "file_name": "string", "entries": "object"},
      "notes": ["Read-only folded structured entries for one SOUL file, including source, epistemic status, evidence, metadata, and revision provenance."],
      "errors": ["400 invalid_target_file", "401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "GET",
      "path": "/v1/soul/summary",
      "authRequired": "conditional",
      "requestSchema": "query params",
      "requiredFields": [],
      "response": {"ok": "bool", "schema": "soul_summary.v1", "subject": "string", "measurements_are_evidence": "bool", "light_cone_breadth": "object", "observed_endorsed_divergence": "object", "persistent_tensions": "object"},
      "notes": ["Read-only SOUL-adjacent continuity measurements. Measurements are not evidence and do not mutate SOUL, beads, claims, associations, myelination, or Dreamer state.", "Dial statuses include complete, partial, and unavailable; limitations describe missing backend support such as non-bead assembly depth or churn history."],
      "errors": ["401 unauthorized", "400 invalid_tenant_id"]
    }
  ]
}
