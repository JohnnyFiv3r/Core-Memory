{
  "version": "v1",
  "service": "core_memory.integrations.http.server",
  "auth": {
    "env": "CORE_MEMORY_HTTP_TOKEN",
    "modes": ["Authorization: Bearer <token>", "X-Memory-Token: <token>"],
    "required_when_env_set": true
  },
  "endpoints": [
    {
      "method": "GET",
      "path": "/healthz",
      "authRequired": false,
      "response": {"ok": "bool"},
      "errors": []
    },
    {
      "method": "POST",
      "path": "/v1/memory/turn-finalized",
      "authRequired": "conditional",
      "requestSchema": "TurnFinalizedRequest",
      "requiredFields": ["session_id", "turn_id", "user_query", "assistant_final"],
      "response": {"accepted": "bool", "event_id": "string"},
      "errors": ["400 invalid_payload|invalid_content_length", "401 unauthorized", "413 payload_too_large"]
    },
    {
      "method": "POST",
      "path": "/v1/memory/classify-intent",
      "authRequired": "conditional",
      "requestSchema": "MemoryClassifyIntentRequest",
      "requiredFields": ["query"],
      "response": {"intent_class": "string", "causal_intent": "bool", "query_type_bucket": "string", "normalized": "object"},
      "errors": ["401 unauthorized"]
    },
    {
      "method": "POST",
      "path": "/v1/memory/search",
      "authRequired": "conditional",
      "requestSchema": "MemorySearchRequest",
      "requiredFields": ["request"],
      "notes": ["`form_submission` accepted as compatibility alias"],
      "response": {"ok": "bool", "results": "array", "chains": "array", "confidence": "string", "suggested_next": "string", "warnings": "array"},
      "errors": ["401 unauthorized", "503 semantic_backend_unavailable"]
    },
    {
      "method": "POST",
      "path": "/v1/memory/trace",
      "authRequired": "conditional",
      "requestSchema": "MemoryTraceRequest",
      "requiredFields": [],
      "response": {"ok": "bool", "anchors": "array", "chains": "array", "grounding": "object", "hydration": "object"},
      "errors": ["401 unauthorized", "503 semantic_backend_unavailable (query-based trace only)"]
    },
    {
      "method": "POST",
      "path": "/v1/memory/execute",
      "authRequired": "conditional",
      "requestSchema": "MemoryExecuteRequest",
      "requiredFields": ["request"],
      "notes": ["Single-call canonical retrieval orchestration path"],
      "response": {"ok": "bool", "request": "object", "snapped": "object", "results": "array", "chains": "array", "grounding": "object", "confidence": "string", "next_action": "string", "warnings": "array", "explain": "object?"},
      "errors": ["401 unauthorized", "memory_execute_disabled", "memory_execute_causal_disabled", "503 semantic_backend_unavailable"]
    },
    {
      "method": "POST",
      "path": "/v1/memory/session-flush",
      "authRequired": "conditional",
      "requestSchema": "SessionFlushRequest",
      "requiredFields": ["session_id"],
      "response": {"ok": "bool"},
      "errors": ["401 unauthorized"]
    },
    {
      "method": "POST",
      "path": "/v1/memory/session-start",
      "authRequired": "conditional",
      "requestSchema": "SessionStartRequest",
      "requiredFields": ["session_id"],
      "response": {"ok": "bool", "created": "bool", "bead_id": "string"},
      "errors": ["401 unauthorized"]
    },
    {
      "method": "GET",
      "path": "/v1/memory/continuity",
      "authRequired": "conditional",
      "requestSchema": "query params",
      "requiredFields": [],
      "notes": ["Pure-read continuity surface; does not create session_start implicitly"],
      "response": {"ok": "bool", "format": "string", "records": "array?", "text": "string?"},
      "errors": ["401 unauthorized"]
    },
    {
      "method": "GET",
      "path": "/v1/ops/async-jobs/status",
      "authRequired": "conditional",
      "requestSchema": "query params",
      "requiredFields": [],
      "response": {"ok": "bool", "schema_version": "core_memory.async_jobs.v1", "queues": "object", "pending_total": "int", "processable_now": "int"},
      "errors": ["401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "POST",
      "path": "/v1/ops/async-jobs/enqueue",
      "authRequired": "conditional",
      "requestSchema": "AsyncJobsEnqueueRequest",
      "requiredFields": ["kind"],
      "notes": ["kind supports: semantic-rebuild, compaction, dreamer-run, neo4j-sync, health-recompute"],
      "response": {"ok": "bool", "schema_version": "core_memory.async_jobs.v1", "kind": "string", "queue": "object", "status": "object"},
      "errors": ["400 unknown_kind", "401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "POST",
      "path": "/v1/ops/async-jobs/run",
      "authRequired": "conditional",
      "requestSchema": "AsyncJobsRunRequest",
      "requiredFields": [],
      "notes": ["Always returns structured status payload; `ok=false` is reported in-body rather than non-200 status.", "run request supports max_side_effects for bounded side-effect drains."],
      "response": {"ok": "bool", "schema_version": "core_memory.async_jobs.v1", "semantic_run": "object", "compaction_run": "object", "side_effect_run": "object", "status_after": "object", "errors": "array"},
      "errors": ["401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "GET",
      "path": "/v1/ops/dreamer/candidates",
      "authRequired": "conditional",
      "requestSchema": "query params",
      "requiredFields": [],
      "response": {"ok": "bool", "count": "int", "results": "array"},
      "errors": ["401 unauthorized", "400 invalid_tenant_id"]
    },
    {
      "method": "POST",
      "path": "/v1/ops/dreamer/candidates/decide",
      "authRequired": "conditional",
      "requestSchema": "DreamerCandidateDecideRequest",
      "requiredFields": ["candidate_id", "decision"],
      "response": {"ok": "bool", "candidate_id": "string", "status": "accepted|rejected", "applied": "object?"},
      "errors": ["400 invalid_decision", "400 candidate_not_found", "401 unauthorized", "400 invalid_tenant_id"]
    }
  ]
}
